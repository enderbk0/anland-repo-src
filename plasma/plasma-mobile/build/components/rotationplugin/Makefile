	cd /data/data/com.termux/files/home/plasmamobile/plasma-mobile/build && $(MAKE) $(MAKESILENT) -f components/rotationplugin/CMakeFiles/rotationplugin.dir/build.make components/rotationplugin/CMakeFiles/rotationplugin.dir/sensorproxy.cpp.o
.PHONY : sensorproxy.cpp.o

sensorproxy.i: sensorproxy.cpp.i
.PHONY : sensorproxy.i

