{
    "$schema": "https://raw.githubusercontent.com/flatpak/flatpak-builder/main/data/flatpak-manifest.schema.json",
    "id": "org.kde.plasma.keyboard",
    "branch": "master",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "plasma-keyboard",
    "tags": [
        "nightly"
    ],
    "desktop-file-name-suffix": " (Nightly)",
    "finish-args": [
        "--share=ipc",
        "--device=dri",
        "--socket=wayland",
        "--socket=inherit-wayland-socket",
        "--env=QML2_IMPORT_PATH=/app/qml:/app/lib/qml:/app/lib64/qml",
        "--env=QT_PLUGIN_PATH=/app/plugins:/app/lib64/plugins:/app/lib/plugins:/usr/share/runtime/lib/plugins"
    ],
    "modules": [
        {
            "name": "qt6-virtualkeyboard",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DQT_DISABLE_RPATH=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://files.kde.org/qt/official_releases/qt/6.10/6.10.3/submodules/qtvirtualkeyboard-everywhere-src-6.10.3.tar.xz",
                    "sha256": "3298e26dfa4fad2363e3dfb2b55079c54fc8115a4a040d9616e5619f095d8fb5",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 7927,
                        "stable-only": true,
                        "versions": {
                            "<": "6.11"
                        },
                        "url-template": "https://files.kde.org/qt/official_releases/qt/${major}.${minor}/$version/submodules/qtvirtualkeyboard-everywhere-src-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "plasma-activities",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_TESTING=OFF"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://invent.kde.org/plasma/plasma-activities.git",
                    "branch": "master"
                }
            ]
        },
        {
            "name": "libplasma",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_TESTING=OFF"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://invent.kde.org/plasma/libplasma.git",
                    "branch": "master"
                }
            ]
        },
        {
            "name": "plasma-keyboard",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
